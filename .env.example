# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by the daily cron (keepalive + price refresh) to write reference
# tables (instruments, prices). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Daily cron auth. Vercel auto-provisions this and sends `Authorization: Bearer <value>`.
# Set it locally only to test /api/cron/daily by hand.
CRON_SECRET=

# LLM provider keys (server-only). Presence = the provider shows "connected" on /integrations.
# The AI assist that consumes them is deferred; set the one(s) you intend to use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
